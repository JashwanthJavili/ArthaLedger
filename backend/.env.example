# Firebase Admin SDK service account JSON path
FIREBASE_ADMIN_CREDENTIALS=./firebase-admin-service-account.json

# Firebase Realtime Database URL (required for DB access)
# e.g. https://your-project-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Comma-separated allowed frontend origins
# Leave empty to allow all (development only)
ALLOWED_ORIGINS=http://localhost:5173

# Rate limit: max requests per IP per minute
RATE_LIMIT_PER_MINUTE=120

# Set to "production" to disable /docs and /redoc
ENVIRONMENT=development
